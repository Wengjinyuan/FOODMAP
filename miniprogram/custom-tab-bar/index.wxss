.tab-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: constant(safe-area-inset-bottom);
  background: #FFFFFF;
  border-top: 2rpx solid #4A3A35;
  display: flex;
  z-index: 999;
}
.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 8rpx 0; min-height: 80rpx;
}
.tab-icon { font-size: 36rpx; margin-bottom: 2rpx; }
.tab-text { font-size: 20rpx; color: #9E8A83; font-weight: 500; }
.tab-item.active .tab-text { color: #4A3A35; font-weight: 700; }
