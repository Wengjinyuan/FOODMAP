/* ═════════════════════════════════════
   元气手绘探店风 — Home Page Styles
   粗描边 + 硬阴影 + 奶油底色 + 暖咖文字
   ═════════════════════════════════════ */

/* ── Page Shell ── */
.page {
  width: 100vw; height: 100vh; overflow: hidden; position: relative;
  background: #FFFDF7;
}

/* ── Map ── */
.map { width: 100%; height: 100%; }

/* ── Top Bar ── */
.top-bar {
  position: absolute; top: 80rpx; left: 20rpx; right: 20rpx;
  height: 72rpx; display: flex; align-items: center; gap: 12rpx; z-index: 10;
}
.search-box {
  flex: 1; height: 72rpx;
  background: rgba(255,255,255,0.95);
  border: 3rpx solid #4A3A35;
  border-radius: 18rpx;
  padding: 0 24rpx;
  display: flex; align-items: center;
}
.search-input {
  flex: 1; font-size: 26rpx; color: #4A3A35;
}
.theme-btn {
  width: 72rpx; height: 72rpx;
  background: rgba(255,255,255,0.95);
  border: 3rpx solid #4A3A35;
  border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; flex-shrink: 0;
}

/* ── FAB ── */
.fab {
  position: absolute; bottom: 300rpx; right: 28rpx;
  width: 100rpx; height: 100rpx;
  background: #FFD23F;
  border: 3rpx solid #4A3A35;
  border-radius: 22rpx;
  z-index: 10;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 3rpx 3rpx 0rpx #4A3A35;
}
.fab-icon { font-size: 48rpx; color: #4A3A35; font-weight: 600; }
.fab:active { transform: scale(0.95); }

/* ── Callout ── */
.callout-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 320rpx;
  display: flex; align-items: flex-end; justify-content: center;
  padding-bottom: 40rpx; z-index: 11;
}
.callout-card {
  width: 85%; background: #FFFFFF;
  border: 3rpx solid #4A3A35;
  border-radius: 14rpx;
  box-shadow: 4rpx 4rpx 0rpx #4A3A35;
  padding: 24rpx; position: relative;
}
.callout-close {
  position: absolute; top: 14rpx; right: 14rpx;
  font-size: 26rpx; padding: 6rpx; color: #9E8A83;
}
.callout-name {
  font-size: 30rpx; font-weight: 700; color: #4A3A35; display: block;
}
.callout-meta {
  display: flex; align-items: center; margin-top: 8rpx; gap: 10rpx;
}
.callout-cat {
  font-size: 24rpx; padding: 4rpx 14rpx;
  color: #4A3A35; background: #FFD23F;
  border: 2rpx solid #4A3A35;
  border-radius: 6rpx; font-weight: 700;
}
.callout-stars { font-size: 24rpx; }
.callout-hint {
  font-size: 22rpx; color: #FF6B6B; margin-top: 12rpx; display: block;
}

/* ── Bottom Drawer ── */
.drawer {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: #FFFDF7;
  border-top: 3rpx solid #4A3A35;
  border-left: 3rpx solid #4A3A35;
  border-right: 3rpx solid #4A3A35;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 9; display: flex; flex-direction: column;
}
.drawer-handle {
  display: flex; justify-content: center; padding: 14rpx 0 8rpx;
}
.drawer-bar {
  width: 48rpx; height: 6rpx;
  background: #4A3A35; border-radius: 4rpx;
}

/* ── Category Chips ── */
.cat-scroll {
  display: flex; white-space: nowrap;
  padding: 4rpx 20rpx 12rpx; height: 60rpx;
}
.cat-chip {
  display: inline-flex; align-items: center;
  padding: 8rpx 22rpx; margin-right: 10rpx;
  background: #FFF9E6; color: #9E8A83;
  border: 2rpx solid #4A3A35; border-radius: 14rpx;
  font-size: 24rpx; flex-shrink: 0;
}
.cat-chip.active {
  background: #FFD23F; color: #4A3A35;
  font-weight: 700;
}

/* ── Waypoint Cards ── */
.card-scroll { flex: 1; padding: 0 20rpx; }
.wp-card {
  display: flex; align-items: center; padding: 16rpx; margin-bottom: 14rpx;
  background: #FFFFFF;
  border: 3rpx solid #4A3A35;
  border-radius: 14rpx;
  box-shadow: 4rpx 4rpx 0rpx #4A3A35;
}
.wp-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx #4A3A35;
}
.card-thumb {
  width: 96rpx; height: 96rpx; border-radius: 10rpx; flex-shrink: 0;
  background: #FFF9E6; border: 2rpx solid #4A3A35;
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.thumb-img  { width: 100%; height: 100%; }
.thumb-emoji { font-size: 40rpx; }
.card-body { flex: 1; margin-left: 16rpx; min-width: 0; }
.card-name {
  font-size: 30rpx; font-weight: 700; color: #4A3A35; display: block;
}
.card-row {
  display: flex; align-items: center; margin-top: 4rpx; gap: 8rpx;
}
.card-cat {
  font-size: 22rpx; padding: 2rpx 10rpx;
  color: #4A3A35; background: #FFD23F;
  border: 2rpx solid #4A3A35; border-radius: 6rpx; font-weight: 700;
}
.card-star { font-size: 22rpx; }
.card-addr {
  font-size: 22rpx; color: #9E8A83; margin-top: 4rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;
}
.card-arrow { font-size: 24rpx; margin-left: 8rpx; color: #C4B5AF; }

/* ── Empty State ── */
.empty-state { text-align: center; padding: 60rpx 0; color: #9E8A83; font-size: 26rpx; }
.empty-hint { display: block; margin-top: 8rpx; font-size: 22rpx; }
