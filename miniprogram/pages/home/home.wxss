/* 传送网 — Home */
page { background: #FFFDF7; }
.map { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }

/* Top bar — 动态避开胶囊 */
.top-bar { position: absolute; left: 20rpx; z-index: 10; display: flex; }
.search-capsule { flex: 1; background: rgba(255,255,255,0.96); border: 2.5rpx solid #4A3A35; border-radius: 34rpx; padding: 0 12rpx 0 20rpx; display: flex; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); box-sizing: border-box; }
.search-icon-left { font-size: 28rpx; margin-right: 10rpx; flex-shrink: 0; }
.search-input { flex: 1; font-size: 26rpx; color: #4A3A35; height: 100%; }
.search-eye { font-size: 26rpx; padding: 8rpx 12rpx; flex-shrink: 0; }
.search-eye.off { opacity: 0.35; }

/* History — 横向翻页卡片 */
.history-panel { position: absolute; top: 156rpx; left: 20rpx; right: 20rpx; background: #FFF; border: 2.5rpx solid #4A3A35; border-radius: 16rpx; box-shadow: 3rpx 3rpx 0 #4A3A35; z-index: 13; padding: 14rpx 16rpx; }
.history-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.history-label { font-size: 22rpx; font-weight: 600; color: #4A3A35; }
.history-clear { font-size: 20rpx; color: #FF6B6B; }
.history-cards { display: flex; white-space: nowrap; }
.h-card { display: inline-flex; align-items: center; padding: 10rpx 20rpx; margin-right: 10rpx; background: #FFF9E6; border: 2rpx solid #4A3A35; border-radius: 10rpx; flex-shrink: 0; }
.h-card-text { font-size: 24rpx; color: #4A3A35; max-width: 160rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.history-dots { display: flex; justify-content: center; gap: 8rpx; margin-top: 10rpx; }
.h-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #E8D5C8; }
.h-dot.active { background: #4A3A35; }

/* Locate button */
.locate-btn { position: absolute; right: 24rpx; width: 80rpx; height: 80rpx; background: #FFF; border: 3rpx solid #4A3A35; border-radius: 18rpx; box-shadow: 3rpx 3rpx 0 #4A3A35; z-index: 10; display: flex; align-items: center; justify-content: center; }
.locate-icon { font-size: 34rpx; color: #4A3A35; font-weight: 600; }

/* FAB */
.fab { position: absolute; right: 24rpx; width: 80rpx; height: 80rpx; background: #FFD23F; border: 3rpx solid #4A3A35; border-radius: 18rpx; box-shadow: 3rpx 3rpx 0 #4A3A35; z-index: 10; display: flex; align-items: center; justify-content: center; }
.fab-icon { font-size: 40rpx; color: #4A3A35; font-weight: 600; }

/* Callout */
.callout-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 340rpx; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 20rpx; z-index: 11; }
.callout-card { width: 80%; background: #FFF; border: 3rpx solid #4A3A35; border-radius: 14rpx; box-shadow: 4rpx 4rpx 0 #4A3A35; padding: 18rpx; position: relative; }
.callout-close { position: absolute; top: 8rpx; right: 10rpx; font-size: 22rpx; color: #9E8A83; }
.callout-name { font-size: 28rpx; font-weight: 700; color: #4A3A35; }
.callout-meta { display: flex; gap: 8rpx; margin-top: 4rpx; }
.callout-cat { font-size: 22rpx; padding: 3rpx 10rpx; color: #4A3A35; background: #FFD23F; border: 2rpx solid #4A3A35; border-radius: 6rpx; font-weight: 700; }
.callout-hint { font-size: 20rpx; color: #FF6B6B; margin-top: 6rpx; }

/* Drawer */
.drawer { position: absolute; bottom: 0; left: 0; right: 0; background: #FFFDF7; border-top: 3rpx solid #4A3A35; border-radius: 24rpx 24rpx 0 0; z-index: 9; display: flex; flex-direction: column; will-change: transform; }
.drawer-drag-zone { flex-shrink: 0; }
.drawer-handle { height: 44rpx; display: flex; justify-content: center; align-items: center; flex-shrink: 0; }
.drawer-bar { width: 40rpx; height: 5rpx; background: #4A3A35; border-radius: 4rpx; }

/* Category chips */
.cat-scroll { width: 100%; padding: 4rpx 16rpx 10rpx; flex-shrink: 0; overflow-x: auto; white-space: nowrap; scrollbar-width: none; }
.cat-scroll::-webkit-scrollbar { display: none; }
.cat-chip { display: inline-flex; align-items: center; padding: 5rpx 14rpx; margin-right: 6rpx; background: #FFF9E6; color: #9E8A83; border: 2rpx solid #4A3A35; border-radius: 10rpx; font-size: 20rpx; }
.cat-chip.active { background: #FFD23F; color: #4A3A35; font-weight: 700; }

/* ── SINGLE COLUMN CARD ── */
.card-scroll { flex: 1; height: 0; min-height: 0; padding: 4rpx 16rpx 16rpx; width: 100%; box-sizing: border-box; }
.wp-card { display: flex; align-items: center; width: 100%; padding: 12rpx; margin-bottom: 6rpx; background: #FFF; border: 2rpx solid #4A3A35; border-radius: 12rpx; box-shadow: 2rpx 2rpx 0 #4A3A35; box-sizing: border-box; }
.card-thumb { width: 96rpx; height: 96rpx; border-radius: 12rpx; flex-shrink: 0; background: #FFF9E6; border: 2rpx solid #4A3A35; display: flex; align-items: center; justify-content: center; font-size: 36rpx; position: relative; overflow: hidden; }
.thumb-img { width: 100%; height: 100%; border-radius: 10rpx; }
.card-pin { position: absolute; bottom: -2rpx; right: -2rpx; font-size: 20rpx; }
.card-info { flex: 1; margin-left: 14rpx; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.card-name { font-size: 26rpx; font-weight: 700; color: #4A3A35; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.card-row { display: flex; align-items: center; gap: 8rpx; margin-top: 4rpx; overflow: hidden; }
.card-cat { font-size: 20rpx; padding: 2rpx 10rpx; color: #4A3A35; background: #FFD23F; border: 1.5rpx solid #4A3A35; border-radius: 4rpx; font-weight: 700; flex-shrink: 0; }
.card-addr { font-size: 22rpx; color: #9E8A83; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; min-width: 0; }
.card-arrow { color: #C4B5AF; font-size: 20rpx; margin-left: 6rpx; flex-shrink: 0; }

/* Empty */
.empty-state { text-align: center; padding: 40rpx 0; color: #9E8A83; font-size: 24rpx; display: flex; flex-direction: column; align-items: center; gap: 14rpx; }
.seed-btn { padding: 12rpx 28rpx; background: #FFD23F; color: #4A3A35; border: 2rpx solid #4A3A35; border-radius: 10rpx; font-size: 22rpx; font-weight: 700; }
