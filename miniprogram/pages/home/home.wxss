/* 传送网 — Home */
.page { width: 100vw; height: 100vh; position: relative; background: #FFFDF7; }
.map { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }

/* Top bar */
.top-bar { position: absolute; top: 80rpx; left: 20rpx; right: 20rpx; height: 64rpx; z-index: 10; }
.search-box { width: 100%; height: 64rpx; background: rgba(255,255,255,0.95); border: 3rpx solid #4A3A35; border-radius: 14rpx; padding: 0 20rpx; display: flex; align-items: center; box-sizing: border-box; }
.search-input { flex: 1; font-size: 26rpx; color: #4A3A35; }

/* History */
.history-drop { position: absolute; top: 150rpx; left: 20rpx; right: 20rpx; background: #FFF; border: 3rpx solid #4A3A35; border-radius: 14rpx; box-shadow: 4rpx 4rpx 0 #4A3A35; z-index: 13; max-height: 360rpx; overflow-y: auto; }
.history-header { display: flex; justify-content: space-between; padding: 10rpx 20rpx; font-size: 22rpx; font-weight: 600; color: #4A3A35; border-bottom: 2rpx dashed #E8D5C8; }
.history-clear { color: #FF6B6B; font-size: 20rpx; }
.history-close { font-size: 28rpx; color: #9E8A83; padding: 0 8rpx; }
.history-item { padding: 12rpx 20rpx; font-size: 24rpx; color: #4A3A35; border-bottom: 1rpx solid #F0EBE5; }

/* FAB */
.fab { position: absolute; right: 24rpx; width: 80rpx; height: 80rpx; background: #FFD23F; border: 3rpx solid #4A3A35; border-radius: 18rpx; box-shadow: 3rpx 3rpx 0 #4A3A35; z-index: 10; display: flex; align-items: center; justify-content: center; }
.fab-icon { font-size: 40rpx; color: #4A3A35; font-weight: 600; }

/* Callout */
.callout-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 340rpx; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 20rpx; z-index: 11; }
.callout-card { width: 80%; background: #FFF; border: 3rpx solid #4A3A35; border-radius: 14rpx; box-shadow: 4rpx 4rpx 0 #4A3A35; padding: 18rpx; position: relative; }
.callout-close { position: absolute; top: 8rpx; right: 10rpx; font-size: 22rpx; color: #9E8A83; padding: 4rpx; }
.callout-name { font-size: 28rpx; font-weight: 700; color: #4A3A35; }
.callout-meta { display: flex; gap: 8rpx; margin-top: 4rpx; }
.callout-cat { font-size: 22rpx; padding: 3rpx 10rpx; color: #4A3A35; background: #FFD23F; border: 2rpx solid #4A3A35; border-radius: 6rpx; font-weight: 700; }
.callout-hint { font-size: 20rpx; color: #FF6B6B; margin-top: 6rpx; }

/* Drawer */
.drawer { position: absolute; bottom: 0; left: 0; right: 0; background: #FFFDF7; border-top: 3rpx solid #4A3A35; border-radius: 24rpx 24rpx 0 0; z-index: 9; display: flex; flex-direction: column; }
.drawer-handle { height: 40rpx; display: flex; justify-content: center; align-items: center; flex-shrink: 0; }
.drawer-bar { width: 40rpx; height: 5rpx; background: #4A3A35; border-radius: 4rpx; }

/* Category row */
.cat-scroll { width: 100%; padding: 4rpx 16rpx 10rpx; flex-shrink: 0; }
.cat-chip { display: inline-flex; align-items: center; padding: 5rpx 14rpx; margin-right: 6rpx; background: #FFF9E6; color: #9E8A83; border: 2rpx solid #4A3A35; border-radius: 10rpx; font-size: 20rpx; }
.cat-chip.active { background: #FFD23F; color: #4A3A35; font-weight: 700; }

/* Layout toggle bar */
.layout-bar { display: flex; justify-content: space-between; align-items: center; padding: 4rpx 16rpx 10rpx; flex-shrink: 0; }
.layout-btn { font-size: 20rpx; color: #4A3A35; background: #FFF9E6; border: 1.5rpx solid #4A3A35; border-radius: 8rpx; padding: 4rpx 14rpx; }

/* ── SINGLE COLUMN CARD ── */
.card-scroll { flex: 1; padding: 0 16rpx 16rpx; }
.wp-card { display: flex; align-items: center; padding: 14rpx; margin-bottom: 8rpx; background: #FFF; border: 2rpx solid #4A3A35; border-radius: 12rpx; box-shadow: 2rpx 2rpx 0 #4A3A35; box-sizing: border-box; }
.wp-card .thumb { width: 80rpx; height: 80rpx; border-radius: 10rpx; flex-shrink: 0; background: #FFF9E6; border: 2rpx solid #4A3A35; display: flex; align-items: center; justify-content: center; font-size: 34rpx; }
.wp-card .info { flex: 1; margin-left: 14rpx; min-width: 0; }
.wp-card .info .name { font-size: 28rpx; font-weight: 700; color: #4A3A35; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wp-card .info .meta { display: flex; gap: 6rpx; align-items: center; margin-top: 4rpx; }
.wp-card .info .cat { font-size: 20rpx; padding: 2rpx 10rpx; color: #4A3A35; background: #FFD23F; border: 1.5rpx solid #4A3A35; border-radius: 4rpx; font-weight: 700; }
.wp-card .info .addr { font-size: 20rpx; color: #9E8A83; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wp-card .arrow { color: #C4B5AF; font-size: 20rpx; margin-left: 4rpx; flex-shrink: 0; }

/* ── DOUBLE COLUMN GRID ── */
.card-grid-scroll { flex: 1; padding: 0 16rpx 16rpx; }
.card-grid { display: flex; flex-wrap: wrap; gap: 10rpx; }
.wp-double { width: calc(50% - 5rpx); background: #FFF; border: 2rpx solid #4A3A35; border-radius: 12rpx; box-shadow: 2rpx 2rpx 0 #4A3A35; overflow: hidden; box-sizing: border-box; }
.wp-double .d-thumb { width: 100%; height: 140rpx; background: #FFF9E6; border-bottom: 2rpx solid #4A3A35; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.wp-double .d-info { padding: 12rpx 14rpx; }
.wp-double .d-name { font-size: 24rpx; font-weight: 700; color: #4A3A35; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wp-double .d-meta { display: flex; gap: 4rpx; margin-top: 4rpx; }
.wp-double .d-cat { font-size: 18rpx; padding: 2rpx 8rpx; color: #4A3A35; background: #FFD23F; border: 1.5rpx solid #4A3A35; border-radius: 4rpx; font-weight: 700; }

/* Empty */
.empty-state { text-align: center; padding: 30rpx 0; color: #9E8A83; font-size: 24rpx; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.seed-btn { padding: 10rpx 24rpx; background: #FFD23F; color: #4A3A35; border: 2rpx solid #4A3A35; border-radius: 10rpx; font-size: 22rpx; font-weight: 700; }
