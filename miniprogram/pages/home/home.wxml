<view class="page {{theme}}">
  <!-- Full-screen map -->
  <map
    id="waypointMap"
    class="map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
    show-location="{{true}}"
    bindmarkertap="onMarkerTap"
    bindregionchange="onMapRegionChange"
  />

  <!-- Top bar: search + theme toggle -->
  <view class="top-bar">
    <view class="search-box">
      <input class="search-input" placeholder="🔍 搜索美食地点..."
        value="{{searchKeyword}}"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
    </view>
    <view class="theme-btn" bindtap="toggleTheme">
      <text>🎨</text>
    </view>
  </view>

  <!-- Search history dropdown -->
  <view class="history-drop" wx:if="{{showHistory && searchHistory.length > 0}}">
    <view class="history-header">
      <text>搜索历史</text>
      <text class="history-clear" bindtap="onClearHistory">清空</text>
    </view>
    <view class="history-item" wx:for="{{searchHistory}}" wx:key="*this"
      bindtap="onHistoryTap" data-keyword="{{item}}">
      <text>🕐 {{item}}</text>
    </view>
  </view>

  <!-- Add waypoint FAB -->
  <view class="fab" bindtap="onAddTap">
    <text class="fab-icon">+</text>
  </view>

  <!-- Marker callout overlay -->
  <view class="callout-overlay" wx:if="{{selectedWaypoint}}" bindtap="onCalloutTap">
    <view class="callout-card">
      <view class="callout-close" catchtap="onCalloutClose">✕</view>
      <text class="callout-name">{{selectedWaypoint.name}}</text>
      <view class="callout-meta">
        <text class="callout-cat">{{selectedWaypoint.category}}</text>
        <text class="callout-stars" wx:if="{{selectedWaypoint.ratingStars}}">{{selectedWaypoint.ratingStars}}</text>
      </view>
      <text class="callout-hint">点击查看详情 ▶</text>
    </view>
  </view>

  <!-- Bottom drawer -->
  <view class="drawer" style="height: {{drawerHeight}}rpx;">
    <!-- 拖拽手柄 - 实时响应 -->
    <view class="drawer-handle"
      bindtouchstart="onDrawerTouchStart"
      bindtouchmove="onDrawerTouchMove"
      bindtouchend="onDrawerTouchEnd">
      <view class="drawer-bar"></view>
    </view>

    <!-- Category filter chips -->
    <scroll-view class="cat-scroll" scroll-x enhanced enable-flex show-scrollbar="{{false}}">
      <view class="cat-chip {{activeCategory === '' ? 'active' : ''}}"
        bindtap="onCategoryTap" data-category="">全部</view>
      <view class="cat-chip {{activeCategory === item ? 'active' : ''}}"
        wx:for="{{categories}}" wx:key="*this"
        bindtap="onCategoryTap" data-category="{{item}}">
        {{item}}
      </view>
    </scroll-view>

    <!-- Waypoint card list -->
    <scroll-view class="card-scroll" scroll-y enhanced enable-flex show-scrollbar="{{false}}"
      refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}"
      bindrefresherrefresh="onRefresh">
      <block wx:if="{{waypoints.length > 0}}">
        <view class="wp-card" wx:for="{{waypoints}}" wx:key="_id"
          bindtap="onCardTap" data-id="{{item._id}}">
          <view class="card-thumb">
            <image wx:if="{{item.images && item.images.length > 0}}"
              src="{{item.images[0]}}" mode="aspectFill" class="thumb-img" />
            <text wx:else class="thumb-emoji">📍</text>
          </view>
          <view class="card-body">
            <text class="card-name">{{item.name}}</text>
            <view class="card-row">
              <text class="card-cat">{{item.category}}</text>
              <text class="card-star" wx:if="{{item.rating > 0}}">⭐{{item.rating}}</text>
            </view>
            <text class="card-addr">{{item.address || '暂无地址'}}</text>
          </view>
          <text class="card-arrow">▶</text>
        </view>
      </block>
      <view class="empty-state" wx:elif="{{!loading}}">
        <text>🔍 附近暂无传送点</text>
        <text class="empty-hint">点击右下角 + 激活第一个传送点吧 ✨</text>
      </view>
      <!-- 底部留白给 TabBar -->
      <view style="height: 40rpx;"></view>
    </scroll-view>
  </view>
</view>
