/* ═════════════════════════════════════
   元气手绘探店风 — Mine Page
   ═════════════════════════════════════ */

.page { height: 100vh; background: #FFFDF7; display: flex; flex-direction: column; overflow: hidden; }

/* ── Stats Header ── */
.stats-box {
  background: #FFFFFF;
  border: 3rpx solid #4A3A35;
  border-radius: 14rpx;
  box-shadow: 4rpx 4rpx 0rpx #4A3A35;
  margin: 24rpx; padding: 28rpx;
  display: flex; align-items: center; gap: 32rpx;
}
.stats-total { flex-shrink: 0; text-align: center; }
.stats-num { font-size: 72rpx; font-weight: 800; color: #FFD23F; display: block; line-height: 1; -webkit-text-stroke: 2rpx #4A3A35; }
.stats-label { font-size: 24rpx; color: #9E8A83; margin-top: 6rpx; display: block; }
.stats-bd { display: flex; flex-wrap: wrap; gap: 16rpx; }
.stats-item { text-align: center; }
.stats-count { font-size: 36rpx; font-weight: 700; color: #4A3A35; display: block; }
.stats-cat { font-size: 20rpx; color: #9E8A83; display: block; }

/* ── Filter Row ── */
.filter-row {
  display: flex; white-space: nowrap;
  padding: 4rpx 24rpx 14rpx;
}
.filter-chip {
  display: inline-flex; padding: 8rpx 22rpx; margin-right: 10rpx;
  background: #FFF9E6; color: #9E8A83;
  border: 2rpx solid #4A3A35; border-radius: 14rpx;
  font-size: 24rpx; flex-shrink: 0;
}
.filter-chip.active { background: #FFD23F; color: #4A3A35; font-weight: 700; }

/* ── Waypoint List ── */
.wp-list { flex: 1; padding: 0 24rpx; height: 0; min-height: 0; }
.wp-card {
  display: flex; align-items: center; padding: 16rpx; margin-bottom: 14rpx;
  background: #FFFFFF;
  border: 3rpx solid #4A3A35;
  border-radius: 14rpx;
  box-shadow: 4rpx 4rpx 0rpx #4A3A35;
}
.wp-card:active { transform: translate(2rpx, 2rpx); box-shadow: 2rpx 2rpx 0rpx #4A3A35; }
.card-thumb {
  width: 96rpx; height: 96rpx; border-radius: 10rpx; flex-shrink: 0;
  background: #FFF9E6; border: 2rpx solid #4A3A35;
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.thumb-img  { width: 100%; height: 100%; }
.thumb-emoji { font-size: 40rpx; }
.card-body { flex: 1; margin-left: 16rpx; min-width: 0; }
.card-name { font-size: 30rpx; font-weight: 700; color: #4A3A35; display: block; }
.card-meta { display: flex; align-items: center; gap: 8rpx; margin-top: 4rpx; }
.card-cat {
  font-size: 22rpx; padding: 2rpx 10rpx;
  color: #4A3A35; background: #FFD23F;
  border: 2rpx solid #4A3A35; border-radius: 6rpx; font-weight: 700;
}
.card-star { font-size: 22rpx; }
.card-addr {
  font-size: 22rpx; color: #9E8A83; margin-top: 4rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;
}
.card-arrow { font-size: 24rpx; margin-left: 8rpx; color: #C4B5AF; }

/* ── Empty ── */
.empty { text-align: center; padding: 80rpx 0; color: #9E8A83; font-size: 26rpx; }
.empty-hint { display: block; margin-top: 8rpx; font-size: 22rpx; }
