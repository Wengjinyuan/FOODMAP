/* 传送网 — Mine */
.page { height: 100vh; background: #FFFDF7; display: flex; flex-direction: column; overflow: hidden; }

.stats-box { margin: 16rpx 20rpx; background: #FFF; border: 3rpx solid #4A3A35; border-radius: 14rpx; box-shadow: 4rpx 4rpx 0 #4A3A35; padding: 22rpx; display: flex; align-items: center; gap: 24rpx; }
.stats-total { flex-shrink: 0; text-align: center; }
.stats-num { font-size: 56rpx; font-weight: 800; color: #FFD23F; display: block; line-height: 1; -webkit-text-stroke: 2rpx #4A3A35; }
.stats-label { font-size: 22rpx; color: #9E8A83; margin-top: 4rpx; display: block; }
.stats-bd { display: flex; flex-wrap: wrap; gap: 14rpx; }
.stats-item { text-align: center; }
.stats-count { font-size: 28rpx; font-weight: 700; color: #4A3A35; display: block; }
.stats-cat { font-size: 20rpx; color: #9E8A83; display: block; }

.filter-row { display: flex; white-space: nowrap; padding: 4rpx 20rpx 10rpx; flex-shrink: 0; }
.filter-chip { display: inline-flex; padding: 5rpx 14rpx; margin-right: 8rpx; background: #FFF9E6; color: #9E8A83; border: 2rpx solid #4A3A35; border-radius: 10rpx; font-size: 20rpx; }
.filter-chip.active { background: #FFD23F; color: #4A3A35; font-weight: 700; }

.wp-list { flex: 1; padding: 0 20rpx 20rpx; }
.wp-card { display: flex; align-items: center; padding: 14rpx; margin-bottom: 8rpx; background: #FFF; border: 2rpx solid #4A3A35; border-radius: 12rpx; box-shadow: 2rpx 2rpx 0 #4A3A35; }
.wp-card .thumb { width: 80rpx; height: 80rpx; border-radius: 10rpx; flex-shrink: 0; background: #FFF9E6; border: 2rpx solid #4A3A35; display: flex; align-items: center; justify-content: center; font-size: 34rpx; }
.wp-card .info { flex: 1; margin-left: 14rpx; min-width: 0; }
.wp-card .info .name { font-size: 28rpx; font-weight: 700; color: #4A3A35; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wp-card .info .meta { display: flex; gap: 6rpx; align-items: center; margin-top: 4rpx; }
.wp-card .info .cat { font-size: 20rpx; padding: 2rpx 10rpx; color: #4A3A35; background: #FFD23F; border: 1.5rpx solid #4A3A35; border-radius: 4rpx; font-weight: 700; }
.wp-card .info .addr { font-size: 20rpx; color: #9E8A83; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wp-card .arrow { color: #C4B5AF; font-size: 20rpx; margin-left: 4rpx; flex-shrink: 0; }

.empty { text-align: center; padding: 60rpx 0; color: #9E8A83; font-size: 24rpx; }
