<view class="page">
  <!-- Stats Header -->
  <view class="stats-box">
    <view class="stats-total">
      <text class="stats-num">{{stats.total}}</text>
      <text class="stats-label">传送点</text>
    </view>
    <view class="stats-bd">
      <view class="stats-item" wx:for="{{stats.categories}}" wx:key="name">
        <text class="stats-count">{{item.count}}</text>
        <text class="stats-cat">{{item.name}}</text>
      </view>
    </view>
    <view style="flex:1;"></view>
    <view class="gear-wrap" catchtap="onOpenSettings">
      <text class="gear-icon">⚙</text>
    </view>
  </view>

  <!-- Category Filter -->
  <view class="filter-row">
    <view class="filter-chip {{activeCategories.length === 0 ? 'active' : ''}}"
      catchtap="onCategoryFilter" data-category="">全部</view>
    <view class="filter-chip {{activeCategoryMap[item.name] ? 'active' : ''}}"
      wx:for="{{stats.categories}}" wx:key="name"
      catchtap="onCategoryFilter" data-category="{{item.name}}">{{item.name}} ({{item.count}})</view>
  </view>

  <!-- Waypoint List -->
  <scroll-view class="wp-list" scroll-y enhanced enable-flex enable-back-to-top show-scrollbar="{{false}}">
    <block wx:if="{{waypoints.length > 0}}">
      <view class="wp-card" wx:for="{{waypoints}}" wx:key="_id" bindtap="onWaypointTap" data-id="{{item._id}}">
        <view class="card-thumb">
          <image wx:if="{{item.images && item.images.length > 0}}" src="{{item.images[0]}}" mode="aspectFill" class="thumb-img" />
          <text wx:else>{{item.categoryEmoji || '📍'}}</text>
          <text class="card-pin">📌</text>
        </view>
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <view class="card-row">
            <text class="card-cat" wx:for="{{item.categories || [item.category || '其他']}}" wx:key="*this" wx:for-item="c">{{c}}</text>
            <text class="card-addr">{{item.address || item.notes || ''}}</text>
          </view>
        </view>
        <text class="card-arrow">▶</text>
      </view>
    </block>
    <view class="empty" wx:elif="{{!loading}}">
      <text>🔍 暂无传送点</text>
      <text class="empty-hint">去地图页激活你的第一个传送点吧 ✨</text>
    </view>
  </scroll-view>
</view>
