<view class="page">
  <!-- Stats Header -->
  <view class="stats-box">
    <view class="stats-total">
      <text class="stats-num">{{stats.total}}</text>
      <text class="stats-label">传送点</text>
    </view>
    <view class="stats-bd">
      <view class="stats-item" wx:for="{{stats.categories}}" wx:for-index="cat" wx:for-item="count" wx:key="cat">
        <text class="stats-count">{{count}}</text>
        <text class="stats-cat">{{cat}}</text>
      </view>
    </view>
  </view>

  <!-- Category Filter -->
  <scroll-view class="filter-row" scroll-x enhanced enable-flex show-scrollbar="{{false}}">
    <view class="filter-chip {{activeCategory === '' ? 'active' : ''}}"
      bindtap="onCategoryFilter" data-category="">全部</view>
    <view class="filter-chip {{activeCategory === cat ? 'active' : ''}}"
      wx:for="{{stats.categories}}" wx:for-index="cat" wx:for-item="count" wx:key="cat"
      bindtap="onCategoryFilter" data-category="{{cat}}">{{cat}} ({{count}})</view>
  </scroll-view>

  <!-- Waypoint List -->
  <scroll-view class="wp-list" scroll-y enhanced enable-flex show-scrollbar="{{false}}">
    <block wx:if="{{waypoints.length > 0}}">
      <view class="wp-card" wx:for="{{waypoints}}" wx:key="_id" bindtap="onWaypointTap" data-id="{{item._id}}">
        <view class="thumb">📍</view>
        <view class="info">
          <view class="name">{{item.name}}</view>
          <view class="meta"><text class="cat">{{item.category}}</text></view>
          <view class="addr">{{item.address || '暂无地址'}}</view>
        </view>
        <text class="arrow">▶</text>
      </view>
    </block>
    <view class="empty" wx:elif="{{!loading}}">
      <text>🔍 暂无传送点</text>
      <text class="empty-hint">去地图页激活你的第一个传送点吧 ✨</text>
    </view>
  </scroll-view>
</view>
