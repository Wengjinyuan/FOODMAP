<view class="page">
  <!-- ═══ VIEW MODE ═══ -->
  <block wx:if="{{mode === 'view'}}">
    <!-- 顶栏：返回 + 标题 -->
    <view class="dnav" style="padding-top:{{navTop}}rpx;">
      <view class="dnav-back" bindtap="onBackToHome">◀</view>
      <text class="dnav-title">{{waypoint.name || '传送点'}}</text>
      <view style="width:64rpx;"></view>
    </view>
    <!-- Image swiper -->
    <swiper class="img-swiper" wx:if="{{waypoint.images && waypoint.images.length > 0}}"
      indicator-dots="{{true}}" indicator-color="rgba(0,0,0,0.2)" indicator-active-color="#4A3A35">
      <swiper-item wx:for="{{waypoint.images}}" wx:key="*this">
        <image class="swiper-img" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>

    <!-- Header -->
    <view class="detail-header {{waypoint.images && waypoint.images.length > 0 ? '' : 'no-image'}}">
      <text class="detail-name">{{waypoint.name}}</text>
      <view class="detail-meta">
        <text class="detail-cat">{{waypoint.category}}</text>
        <text class="detail-stars" wx:if="{{waypoint.rating > 0}}">{{waypoint.ratingStars}}</text>
      </view>
    </view>

    <!-- Info -->
    <view class="info-card">
      <view class="info-row" wx:if="{{waypoint.address}}">
        <text class="info-label">📍 地址</text>
        <text class="info-value">{{waypoint.address}}</text>
      </view>
      <view class="info-row" wx:if="{{waypoint.notes}}">
        <text class="info-label">📝 备注</text>
        <text class="info-value">{{waypoint.notes}}</text>
      </view>
      <view class="info-row" wx:if="{{waypoint.tags && waypoint.tags.length > 0}}">
        <text class="info-label">🏷️ 标签</text>
        <text class="info-value">{{waypoint.tags}}</text>
      </view>
    </view>

    <!-- 图片画廊（在详情中展示） -->
    <view class="detail-gallery" wx:if="{{waypoint.images && waypoint.images.length > 0}}">
      <image class="gallery-img" wx:for="{{waypoint.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" catchtap="onPreviewImage" data-src="{{item}}" />
    </view>

    <!-- 小地图 -->
    <view class="detail-map-wrap" wx:if="{{waypoint.location}}">
      <map class="detail-map" latitude="{{form.latitude}}" longitude="{{form.longitude}}"
        scale="15" markers="{{detailMapMarkers}}" show-location="{{false}}"
        enable-zoom="{{false}}" enable-scroll="{{false}}" enable-rotate="{{false}}" />
    </view>

    <!-- Actions -->
    <view class="action-bar">
      <button class="nav-btn" bindtap="onNavigate">⚡ 开始传送</button>
      <button class="edit-btn" bindtap="onEdit">✏️ 编辑</button>
    </view>
  </block>

  <!-- ═══ EDIT / ADD MODE ═══ -->
  <block wx:if="{{mode === 'edit' || mode === 'add'}}">
    <!-- 固定顶栏：返回 + 标题 -->
    <view class="form-nav" style="padding-top:{{navTop}}rpx;">
      <view class="form-back" bindtap="onCancel">◀</view>
      <text class="form-nav-title">{{mode === 'add' ? '⚡ 激活新传送点' : '✏️ 编辑传送点'}}</text>
      <view style="width:64rpx;"></view>
    </view>
    <!-- 可滚动表单区，高度避开顶栏和底栏 -->
    <scroll-view class="form-scroll" scroll-y show-scrollbar="{{false}}">
      <view class="form-section">

        <!-- Name -->
        <view class="field required">
          <text class="field-label">传送点名称</text>
          <input class="field-input" placeholder="比如：张记烧烤大排档" value="{{form.name}}" bindinput="onFormField" data-field="name" maxlength="50" />
        </view>

        <!-- Category -->
        <view class="field required">
          <text class="field-label">分类</text>
          <view class="chip-grid">
            <view class="chip {{form.category === item ? 'selected' : ''}}"
              wx:for="{{categories}}" wx:key="*this"
              catchtap="onCategorySelect" data-category="{{item}}">{{item}}</view>
          </view>
          <!-- 选了"其他"才出现自定义输入 -->
          <view class="custom-row" wx:if="{{form.category === '其他'}}" style="margin-top:12rpx;">
            <input class="custom-input" placeholder="输入新分类名称..." value="{{customCategory}}" bindinput="onCustomCategoryInput" maxlength="10" />
            <view class="custom-btn" catchtap="onAddCustomCategory">+</view>
          </view>
          <!-- 删除分类（默认分类最少剩1个） -->
          <view class="manage-row" style="margin-top:12rpx;">
            <text class="manage-btn" catchtap="onManageCategories">🗑️ 管理分类</text>
          </view>
        </view>

        <!-- Address -->
        <view class="field">
          <text class="field-label">地址</text>
          <input class="field-input" placeholder="手动输入地址，如：朝阳区建国路88号" value="{{form.address}}" bindinput="onFormField" data-field="address" />
        </view>
        <!-- Map picker -->
        <view class="field">
          <text class="field-label">位置</text>
          <view class="location-pick" bindtap="onChooseLocation">
            <text wx:if="{{form.latitude}}">📍 已选点 ({{form.latitude}}, {{form.longitude}})</text>
            <text wx:else class="placeholder">点击打开地图选点（可选）</text>
          </view>
        </view>

        <!-- Rating -->
        <view class="field">
          <text class="field-label">评分</text>
          <view class="star-row">
            <text class="star {{index < form.rating ? 'active' : ''}}"
              wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
              bindtap="onRatingTap" data-rating="{{item}}">★</text>
          </view>
        </view>

        <!-- Tags -->
        <view class="field">
          <text class="field-label">标签</text>
          <view class="chip-grid">
            <view class="chip {{form.tags.indexOf(item) > -1 ? 'selected' : ''}}"
              wx:for="{{presetTags}}" wx:key="*this"
              catchtap="onTagToggle" data-tag="{{item}}">{{item}}</view>
          </view>
          <!-- 用户历史标签（折叠展开） -->
          <view class="field-sub" wx:if="{{userTags.length > 0}}" style="margin-top:12rpx;">
            <text class="field-sub-title" catchtap="onToggleUserTags">
              {{showUserTags ? '▾' : '▸'}} 我的标签 ({{userTags.length}})
            </text>
            <view class="chip-grid" wx:if="{{showUserTags}}" style="margin-top:8rpx;">
              <view class="chip {{form.tags.indexOf(item) > -1 ? 'selected' : ''}}"
                wx:for="{{userTags}}" wx:key="*this"
                catchtap="onTagToggle" data-tag="{{item}}">{{item}}</view>
            </view>
          </view>
          <!-- 自定义输入 -->
          <view class="custom-row" style="margin-top:12rpx;">
            <input class="custom-input" placeholder="输入新标签..." value="{{customTag}}" bindinput="onCustomTagInput" maxlength="10" />
            <view class="custom-btn" catchtap="onAddCustomTag">+</view>
          </view>
          <!-- 删除已选标签 -->
          <view class="manage-row" wx:if="{{form.tags.length > 0}}" style="margin-top:12rpx;">
            <text class="tag-del-chip" wx:for="{{form.tags}}" wx:key="*this" catchtap="onRemoveTag" data-tag="{{item}}">{{item}} ✕</text>
          </view>
        </view>

        <!-- Images -->
        <view class="field">
          <text class="field-label">图片 ({{form.images.length}}/6)</text>
          <view class="img-grid">
            <view class="img-item" wx:for="{{form.images}}" wx:key="*this">
              <image class="img-preview" src="{{item}}" mode="aspectFill" />
              <view class="img-remove" bindtap="onRemoveImage" data-index="{{index}}">✕</view>
            </view>
            <view class="img-add" wx:if="{{form.images.length < 6}}" bindtap="onChooseImage">
              <text class="img-add-icon">+</text>
            </view>
          </view>
        </view>

        <!-- Notes -->
        <view class="field">
          <text class="field-label">备注</text>
          <textarea class="field-textarea" placeholder="好吃的菜品、避坑指南..." value="{{form.notes}}" bindinput="onFormField" data-field="notes" maxlength="500" />
        </view>
      </view>
    </scroll-view>

    <!-- Bottom actions -->
    <view class="form-actions">
      <button class="cancel-btn" bindtap="onCancel">取消</button>
      <button class="submit-btn" bindtap="onSubmit" disabled="{{submitting}}">
        {{submitting ? '保存中...' : (mode === 'add' ? '⚡ 激活' : '💾 保存')}}
      </button>
      <button class="del-btn" wx:if="{{mode === 'edit'}}" bindtap="onDelete">🗑️</button>
    </view>
  </block>
</view>
