/* ═════════════════════════════════════
   元气手绘探店风 — Detail Page
   ═════════════════════════════════════ */

.page { height: 100vh; background: #FFFDF7; display: flex; flex-direction: column; overflow: hidden; }

/* ── Common Nav ── */
.dnav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 20rpx 12rpx; flex-shrink: 0; background: #FFFDF7; display: flex; align-items: center; justify-content: space-between;
}
.dnav-back {
  width: 64rpx; height: 64rpx; background: #FFFFFF;
  border: 2rpx solid #4A3A35; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #4A3A35;
}
.dnav-title { font-size: 32rpx; font-weight: 700; color: #4A3A35; text-align: center; }

/* ── View Mode: Image Swiper ── */
.img-swiper { width: 100%; height: 480rpx; }
.swiper-img { width: 100%; height: 100%; }

/* ── View Mode: Header ── */
.detail-header { padding: 32rpx 24rpx 16rpx; }
.detail-header.no-image { padding-top: 40rpx; }
.detail-name { font-size: 40rpx; font-weight: 700; color: #4A3A35; display: block; }
.detail-meta { display: flex; align-items: center; gap: 16rpx; margin-top: 12rpx; }
.detail-cat {
  font-size: 24rpx; padding: 6rpx 18rpx;
  color: #4A3A35; background: #FFD23F;
  border: 2rpx solid #4A3A35; border-radius: 6rpx; font-weight: 700;
}
.detail-stars { font-size: 26rpx; }

/* ── View Mode: Info Card ── */
.info-card {
  margin: 16rpx 24rpx; background: #FFFFFF;
  border: 3rpx solid #4A3A35; border-radius: 14rpx;
  box-shadow: 4rpx 4rpx 0rpx #4A3A35; padding: 24rpx;
}
.info-row {
  display: flex; padding: 14rpx 0;
  border-bottom: 2rpx dashed #E8D5C8;
}
.info-row:last-child { border-bottom: none; }
.info-label { width: 120rpx; font-size: 26rpx; color: #9E8A83; flex-shrink: 0; }
.info-value { flex: 1; font-size: 26rpx; color: #4A3A35; line-height: 1.5; }

/* ── View Mode: Mini Map ── */
.detail-map-wrap { margin: 16rpx 24rpx; border: 3rpx solid #4A3A35; border-radius: 14rpx; overflow: hidden; height: 320rpx; }
.detail-map { width: 100%; height: 100%; }

/* ── View Mode: Actions ── */
.action-bar { display: flex; margin: 24rpx; gap: 16rpx; }
.nav-btn {
  flex: 1; height: 88rpx; background: #FFD23F;
  color: #4A3A35; border: 3rpx solid #4A3A35;
  border-radius: 14rpx; box-shadow: 3rpx 3rpx 0rpx #4A3A35;
  font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.nav-btn:active { transform: translate(2rpx, 2rpx); box-shadow: 1rpx 1rpx 0rpx #4A3A35; }
.edit-btn {
  width: 88rpx; height: 88rpx; background: #FFFFFF;
  color: #4A3A35; border: 3rpx solid #4A3A35;
  border-radius: 14rpx; font-size: 32rpx;
  display: flex; align-items: center; justify-content: center;
}

/* ── Edit Mode: Fixed Nav ── */
.form-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 20rpx 12rpx; flex-shrink: 0; background: #FFFDF7; display: flex; align-items: center; justify-content: space-between;
}
.form-back {
  width: 64rpx; height: 64rpx; background: #FFFFFF;
  border: 2rpx solid #4A3A35; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #4A3A35;
}
.form-nav-title { font-size: 32rpx; font-weight: 700; color: #4A3A35; }

/* ── Edit Mode: Form ── */
.form-scroll {
  flex: 1;
  /* 确保不超出父容器，避免顶栏底栏被遮挡 */
  height: 0;
  min-height: 0;
}
.form-section { padding: 0 24rpx 24rpx; }

.field { margin-bottom: 28rpx; }
.field.required .field-label::after { content: ' *'; color: #FF6B6B; }
.field-label { font-size: 26rpx; color: #4A3A35; display: block; margin-bottom: 10rpx; font-weight: 600; }

.field-input {
  width: 100%; height: 80rpx; background: #FFFFFF;
  border: 3rpx solid #4A3A35; border-radius: 12rpx;
  padding: 0 20rpx; font-size: 28rpx; color: #4A3A35; box-sizing: border-box;
}
.field-textarea {
  width: 100%; height: 180rpx; background: #FFFFFF;
  border: 3rpx solid #4A3A35; border-radius: 12rpx;
  padding: 20rpx; font-size: 28rpx; color: #4A3A35; box-sizing: border-box;
}

/* Chips */
.chip-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip {
  padding: 10rpx 22rpx; background: #FFF9E6;
  border: 2rpx solid #4A3A35; border-radius: 14rpx;
  font-size: 26rpx; color: #9E8A83;
}
.chip.selected { background: #FFD23F; color: #4A3A35; font-weight: 700; }

/* Location picker */
.location-pick {
  min-height: 80rpx; background: #FFFFFF;
  border: 3rpx dashed #4A3A35; border-radius: 12rpx;
  padding: 20rpx; font-size: 26rpx; color: #4A3A35;
  display: flex; align-items: center;
}
.placeholder { color: #C4B5AF; }

/* Stars */
.star-row { display: flex; gap: 6rpx; }
.star { font-size: 48rpx; color: #E8D5C8; }
.star.active { color: #FFD23F; }

/* Sub-field (collapse) */
.field-sub-title { font-size: 24rpx; color: #9E8A83; padding: 8rpx 0; display: block; }

/* Custom tag */
.custom-row { display: flex; gap: 10rpx; margin-top: 12rpx; }
.custom-input {
  flex: 1; height: 64rpx; background: #FFFFFF;
  border: 2rpx solid #4A3A35; border-radius: 12rpx;
  padding: 0 20rpx; font-size: 26rpx; color: #4A3A35;
}
.custom-btn {
  width: 64rpx; height: 64rpx; background: #FFD23F;
  border: 2rpx solid #4A3A35; border-radius: 12rpx;
  color: #4A3A35; font-size: 32rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}

/* Image grid */
.img-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }
.img-item { position: relative; width: 200rpx; height: 200rpx; }
.img-preview { width: 100%; height: 100%; border-radius: 10rpx; border: 2rpx solid #4A3A35; }
.img-remove {
  position: absolute; top: -8rpx; right: -8rpx;
  width: 40rpx; height: 40rpx; background: #FF6B6B; color: #FFFFFF;
  border: 2rpx solid #4A3A35; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx;
}
.img-add {
  width: 200rpx; height: 200rpx; background: #FFF9E6;
  border: 3rpx dashed #4A3A35; border-radius: 10rpx;
  display: flex; align-items: center; justify-content: center;
}
.img-add-icon { font-size: 56rpx; color: #C4B5AF; }

/* Form actions */
.form-actions {
  padding: 16rpx 24rpx 40rpx; background: #FFFDF7;
  display: flex; gap: 12rpx;
  border-top: 3rpx solid #4A3A35;
  flex-shrink: 0;
}
.cancel-btn {
  flex: 3; height: 88rpx; background: #FFFFFF;
  color: #9E8A83; border: 2rpx solid #9E8A83;
  border-radius: 14rpx; font-size: 28rpx;
  display: flex; align-items: center; justify-content: center;
}
.submit-btn {
  flex: 7; height: 88rpx; background: #FFD23F;
  color: #4A3A35; border: 3rpx solid #4A3A35;
  border-radius: 14rpx; box-shadow: 3rpx 3rpx 0rpx #4A3A35;
  font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.submit-btn[disabled] { opacity: 0.5; }
.submit-btn:active { transform: translate(2rpx, 2rpx); box-shadow: 1rpx 1rpx 0rpx #4A3A35; }
.del-btn {
  width: 88rpx; height: 88rpx; background: #FFFFFF;
  color: #FF6B6B; border: 3rpx solid #FF6B6B;
  border-radius: 14rpx; font-size: 32rpx;
  display: flex; align-items: center; justify-content: center;
}
