<view class="page">
  <view class="snav" style="padding-top:{{navTop}}rpx;">
    <view class="snav-back" bindtap="onBack">◀</view>
    <text class="snav-title">设置</text>
    <view style="width:64rpx;"></view>
  </view>

  <view class="stab-row">
    <view class="stab {{tab==='cards'?'active':''}}" bindtap="switchTab" data-tab="cards">卡片 ({{cards.length}})</view>
    <view class="stab {{tab==='tags'?'active':''}}" bindtap="switchTab" data-tab="tags">标签 ({{tags.length}})</view>
    <view class="stab {{tab==='categories'?'active':''}}" bindtap="switchTab" data-tab="categories">分类 ({{categories.length}})</view>
  </view>

  <view class="sbar">
    <input class="sb-search" placeholder="搜索..." value="{{search}}" bindinput="onSearch" />
    <text class="sbar-btn" bindtap="toggleAll">☑</text>
    <text class="sbar-btn del" bindtap="batchDelete">🗑️</text>
    <text class="sbar-btn add" wx:if="{{tab !== 'cards'}}" bindtap="addItem">＋</text>
  </view>

  <!-- Cards -->
  <scroll-view class="slist" wx:if="{{tab === 'cards'}}" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="wp-card" wx:for="{{filteredCards}}" wx:key="_id" catchtap="toggleCheck" data-key="{{item._id}}">
      <view class="scheck {{checked[item._id] ? 'on' : ''}}">{{checked[item._id] ? '☑' : '☐'}}</view>
      <view class="card-thumb">📍</view>
      <view class="card-info">
        <text class="card-name">{{item.name}}</text>
        <text class="card-addr">{{item.category}}</text>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{cards.length===0}}">暂无卡片</view>
  </scroll-view>

  <!-- Tags -->
  <scroll-view class="slist" wx:if="{{tab === 'tags'}}" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="stag-row">
      <view class="stag-item {{checked[item] ? 'on' : ''}}" wx:for="{{filteredTags}}" wx:key="*this"
        catchtap="toggleCheck" data-key="{{item}}">
        <view class="stag-chip">
          <text>🏷️ {{item}}</text>
          <text class="stag-edit" catchtap="renameItem" data-name="{{item}}">✏️</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{tags.length===0}}">暂无自定义标签</view>
  </scroll-view>

  <!-- Categories -->
  <scroll-view class="slist" wx:if="{{tab === 'categories'}}" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="stag-row">
      <view class="stag-item {{checked[item.name] ? 'on' : ''}}" wx:for="{{filteredCategories}}" wx:key="name"
        catchtap="toggleCheck" data-key="{{item.name}}">
        <view class="stag-chip">
          <text>📂 {{item.name}} ({{item.count}})</text>
          <text class="stag-edit" catchtap="renameItem" data-name="{{item.name}}">✏️</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{categories.length===0}}">暂无分类</view>
  </scroll-view>
</view>
